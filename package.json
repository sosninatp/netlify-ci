{
  "name": "start-project",
  "version": "1.0.0",
  "description": "start project gulp prettier",
  "license": "ISC",
  "author": "",
  "type": "commonjs",
  "main": "index.js",
  "scripts": {
    "test": "echo 'Привет!'",
    "check": "prettier --check './src/**/*.{html,css,js}'",
    "format": "prettier --write './src/**/*.{html,css,js}'",
    "lint": "stylelint './src/**/*.css'",
    "lintfix": "stylelint './src/**/*.css' --fix",
    "checkAll": "npm run check && npm run lint",
    "fixAll": "npm run format && npm run lintfix",
    "build": "gulp build",
    "dev": "gulp",
    "fixAndBuild": "npm run fixAll && npm run build"
  },
  "devDependencies": {
    "browser-sync": "^3.0.4",
    "del": "^6.0.0",
    "gulp": "^5.0.1",
    "gulp-concat-css": "^3.1.0",
    "gulp-plumber": "^1.2.1",
    "prettier": "^3.8.3",
    "stylelint": "^17.7.0"
  }
}
